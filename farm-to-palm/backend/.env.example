# Database (use with docker-compose postgres)
DATABASE_URL=postgres://farmtopalm:farmtopalm_secret@localhost:5432/farmtopalm

# JWT signing (change in production)
JWT_SECRET=change-me-in-production

# 32-byte hex key for biometric template encryption
BIOMETRIC_ENC_KEY=0123456789abcdef0123456789abcdef

# Optional: base URL returned to terminals on activation
# API_BASE_URL=http://localhost:3000

PORT=3000
